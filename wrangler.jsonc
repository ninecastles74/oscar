{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "oscar",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": [
    "nodejs_compat_populate_process_env","nodejs_compat"],
  "main": "src/server.ts",
  "vars": {
    "MULTI_MODEL_VERIFICATION_ENABLED": "true",
    "SCHEDULED_USE_MULTI_MODEL": "true",
    "MANUAL_ANALYSIS_WALL_MS": "90000",
    "LIVE_EVIDENCE_CLAIM_TIMEOUT_MS": "20000",
    "LIVE_EVIDENCE_MAX_CLAIMS": "5",
    "LIVE_EVIDENCE_BATCH_SIZE": "2",
    "LIVE_EVIDENCE_CLAIM_RETRIES": "2",
    "MANUAL_MULTIMODEL_CONCURRENCY": "2",
    "GEMINI_FETCH_TIMEOUT_MS": "20000",
    "LLM_FETCH_TIMEOUT_MS": "30000",
    "RSS_USE_DEFAULT_REGISTRY": "true",
    "NEWS_INGEST_ENABLED_PROVIDERS": "rss",
    "NEWS_INGEST_COUNTRY": "us",
    "NEWS_INGEST_LANGUAGE": "en",
    "SCHEDULED_NEWS_ENABLED": "true"
  },
  // Free Workers: max 5 cron triggers per *account* (not per Worker). Keep ≤4 here
  // if you use crons on other Workers. Daily reliability jobs share one schedule.
  "triggers": {
    "crons": [
      "0 */8 * * *",
      "*/30 * * * *",
      "0 */4 * * *",
      "0 2 * * *"
    ]
  },
  // Required for live Top 100 across requests/cron — see docs/CLOUDFLARE_NEWS_SETUP.md
  // 1) npx wrangler kv namespace create OSCAR_FEED
  // 2) Uncomment and paste the namespace id:
  // "kv_namespaces": [{ "binding": "FEED_KV", "id": "YOUR_KV_NAMESPACE_ID" }]
}
