# =============================================================================
# OSCAR — Cloudflare Wrangler local secrets (copy to .dev.vars — gitignored)
# =============================================================================
#   cp .dev.vars.example .dev.vars
# Same keys as .env.example. Wrangler injects these into process.env during
# `vite dev` / `wrangler dev` with the Cloudflare plugin.
# =============================================================================

# --- News ingest (Top 100) — minimum without paid APIs ---
RSS_USE_DEFAULT_REGISTRY=true
NEWS_INGEST_ENABLED_PROVIDERS=rss
SCHEDULED_NEWS_ENABLED=true
# Do not set SCHEDULED_NEWS_CRON unless it matches wrangler.jsonc (default 0 */8 * * *)

# Optional paid providers (Wrangler secrets in production):
# NEWS_API_KEY=
# GNEWS_API_KEY=
# GUARDIAN_API_KEY=

# --- Gemini / Google AI (use any one secret name on Workers) ---
#
# LOCAL (.dev.vars / .env) — use NAME=value on one line:
#   GEMINI_API_KEY=AIzaSyC_your_key_here
#
# CLOUDFLARE DASHBOARD (Workers → oscar → Settings → Secrets) — two fields:
#   Name:  GEMINI_API_KEY          ← no trailing "=" on the name
#   Value: AIzaSyC_your_key_here    ← ONLY the key, NOT "GEMINI_API_KEY=..."
#
# GOOGLE_AI_API_KEY=
# GEMINI_API_KEY=
# GEMINI_VERIFICATION_MODEL=gemini-2.5-flash
# GEMINI_ENABLE_GOOGLE_SEARCH=true
# GEMINI_FETCH_TIMEOUT_MS=25000

# --- Ask Oscar manual analysis ---
# Returns immediately; analysis runs in the background (Workers waitUntil).
# FINAL_INTELLIGENCE_ON_MANUAL=true  # optional; adds ~30s+ per run
# MANUAL_MULTIMODEL_MAX_CLAIMS=5
# LLM_FETCH_TIMEOUT_MS=12000

# --- Supabase (analysis persistence; not required for Top 100 feed) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ENABLED=true
DATABASE_URL=
DIRECT_URL=
