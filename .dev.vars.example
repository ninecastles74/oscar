# =============================================================================
# OSCAR — Cloudflare Wrangler local secrets (copy to .dev.vars — gitignored)
# =============================================================================
#   cp .dev.vars.example .dev.vars
# Same keys as .env.example. Wrangler injects these into process.env during
# `vite dev` / `wrangler dev` with the Cloudflare plugin.
# =============================================================================

# --- News ingest (Top 100) — minimum without paid APIs ---
RSS_USE_DEFAULT_REGISTRY=true
NEWS_INGEST_ENABLED_PROVIDERS=rss
SCHEDULED_NEWS_ENABLED=true
# Do not set SCHEDULED_NEWS_CRON unless it matches wrangler.jsonc (default 0 */8 * * *)

# Optional paid providers (Wrangler secrets in production):
# NEWS_API_KEY=
# GNEWS_API_KEY=
# GUARDIAN_API_KEY=

# --- Supabase (analysis persistence; not required for Top 100 feed) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ENABLED=true
DATABASE_URL=
DIRECT_URL=
