# =============================================================================
# OSCAR — Environment template (copy to .env and .dev.vars — both gitignored)
# =============================================================================
#   npm run env:setup
# Server secrets: Cloudflare Workers → Variables & Secrets (never commit real keys)
# Browser: only VITE_* vars below (anon key is public by design)
# =============================================================================

# --- Browser (Vite) — Supabase auth only ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- Supabase / Prisma (server only) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ENABLED=true
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- News ingest (Top 100) — minimum without paid APIs ---
RSS_USE_DEFAULT_REGISTRY=true
NEWS_INGEST_ENABLED_PROVIDERS=rss
NEWS_INGEST_COUNTRY=us
NEWS_INGEST_LANGUAGE=en
SCHEDULED_NEWS_ENABLED=true
# SCHEDULED_NEWS_CRON=0 */8 * * *
# SCHEDULED_ANALYSIS_MAX_CLUSTERS=12

# Optional paid news providers (server secrets in production):
# NEWS_API_KEY=
# GNEWS_API_KEY=
# GUARDIAN_API_KEY=

# --- AI providers (server only — never VITE_*) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Google Gemini (any one name works on Workers):
# GOOGLE_AI_API_KEY=
# GEMINI_API_KEY=
# GEMINI_VERIFICATION_MODEL=gemini-2.5-flash-lite  # or gemini-2.5-flash with billing
# GEMINI_ENABLE_GOOGLE_SEARCH=true
# GEMINI_FETCH_TIMEOUT_MS=25000
# GEMINI_MIN_REQUEST_INTERVAL_MS=4500
# LIVE_EVIDENCE_MAX_CLAIMS=5
MULTI_MODEL_VERIFICATION_ENABLED=true
# SCHEDULED_USE_MULTI_MODEL=false

# --- Cron / ingest auth ---
# CRON_SECRET=

# --- Usage & billing ---
FREE_DAILY_AI_ANALYSES=5
# PRO_DAILY_AI_ANALYSES=50
# TEAM_DAILY_AI_ANALYSES=200

# --- Final intelligence orchestration (manual analysis) ---
FINAL_INTELLIGENCE_ON_MANUAL=true

# --- Reliability jobs ---
# RELIABILITY_JOBS_ENABLED=true
