# =============================================================================
# Veridict — News ingestion (server-only)
# =============================================================================
# Copy to .dev.vars for Cloudflare Wrangler local dev, or set in your host's
# secret store. Never prefix with VITE_ — these must not reach the browser.
# =============================================================================

# --- API keys (required per provider you enable) ---
NEWS_API_KEY=
GNEWS_API_KEY=
GUARDIAN_API_KEY=

# --- Which providers to run (comma-separated). Defaults to all if unset. ---
# Options: newsapi, gnews, guardian, rss, publishers
NEWS_INGEST_ENABLED_PROVIDERS=newsapi,gnews,guardian,rss,publishers

# --- RSS feed registry ---
# Built-in major publishers (BBC, Reuters, AP, NPR, Guardian, NYT, Politico, Axios, etc.)
RSS_USE_DEFAULT_REGISTRY=true
# Limit to specific registry ids (comma-separated); empty = all enabled defaults
# RSS_ENABLED_FEED_IDS=bbc-top,reuters-top,ap-top,guardian-world
# Disable specific registry ids
# RSS_DISABLED_FEED_IDS=cnn-top
# Extra registry entries or overrides (JSON array, same shape as defaults)
# RSS_FEEDS_JSON=[{"id":"custom-feed","name":"Custom","domain":"example.com","feedUrl":"https://example.com/rss","category":"General","enabled":true}]
# Legacy: additional anonymous feed URLs (merged into registry)
RSS_FEED_URLS=

# --- Manual publisher feeds (JSON array) ---
# Each entry: id, name, domain, feedUrl, optional category/language/reliability
PUBLISHER_FEEDS_JSON=[{"id":"reuters-rss","name":"Reuters","domain":"reuters.com","feedUrl":"https://www.reutersagency.com/feed/","category":"World","reliability":96},{"id":"ap-rss","name":"Associated Press","domain":"apnews.com","feedUrl":"https://apnews.com/hub/ap-top-news?output=rss","category":"General","reliability":95}]

# --- Ingestion defaults ---
NEWS_INGEST_COUNTRY=us
NEWS_INGEST_LANGUAGE=en
NEWS_INGEST_MAX_ARTICLES_PER_PROVIDER=100
NEWS_FETCH_TIMEOUT_MS=15000

# --- Per-provider rate limits (requests per minute, in-process sliding window) ---
NEWSAPI_RATE_LIMIT_PER_MIN=30
GNEWS_RATE_LIMIT_PER_MIN=30
GUARDIAN_RATE_LIMIT_PER_MIN=60
RSS_RATE_LIMIT_PER_MIN=120
PUBLISHERS_RATE_LIMIT_PER_MIN=120

# --- LLM keys (topic classification + multi-model verification) ---
OPENAI_API_KEY=
OPENAI_TOPIC_MODEL=gpt-4o-mini
OPENAI_VERIFICATION_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_VERIFICATION_MODEL=claude-3-5-haiku-20241022
GOOGLE_AI_API_KEY=
GEMINI_VERIFICATION_MODEL=gemini-2.0-flash
# Run OpenAI → Claude (disputed) → Gemini → consensus after base pipeline
MULTI_MODEL_VERIFICATION_ENABLED=true

# --- PostgreSQL (Prisma) — reliability & verification persistence ---
# postgresql://USER:PASSWORD@HOST:5432/veridict?schema=public
DATABASE_URL=

# --- Scheduled reliability jobs (Cloudflare cron + manual API) ---
RELIABILITY_JOBS_ENABLED=true
# Protect POST /api scheduled job triggers (optional; unset = no auth in dev)
CRON_SECRET=
# Override default cron → job mapping (JSON array of { jobId, cron, enabled })
# RELIABILITY_JOB_CRONS_JSON=
